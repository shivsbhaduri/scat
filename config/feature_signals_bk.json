                },
                {
                    "field": "transaction_type",
                    "match_type": "equals",
                    "value": "Credit"
                }
            ],
            "hint_category": "card_payments"
        },
        {
            "feature_name": "is_card_fee_debit",
            "conditions": [
                {
                    "field": "description",
                    "match_type": "any_contains",
                    "keywords": [
                        "dojouk ps",
                        "evo payments",
                        "stripe-"
                    ]
                },
                {
                    "field": "transaction_type",
                    "match_type": "equals",
                    "value": "Debit"
                }
            ],
            "hint_category": "card_processing_fees"
        }
    ]
}