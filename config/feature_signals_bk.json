    "regex_features": [
        {
            "feature_name": "is_internal_transfer_bx",
            "pattern": "^bx\\d{8}",
            "fields": [
                "description"
            ],
            "hint_category": "internal_transfers"
        },
        {
            "feature_name": "is_faster_payment_receipt",
            "pattern": "^faster payments receipt ref\\.",
            "fields": [
                "description"
            ],
            "hint_category": "bank_transfers_in"
        },
        {
            "feature_name": "is_bank_giro_credit",
            "pattern": "^bank giro credit ref",
            "fields": [
                "description"
            ],
            "hint_category": "card_payments"
        },
        {
            "feature_name": "is_advice_confirms",
            "pattern": "^advice confirms",
            "fields": [
                "description"
            ],
            "hint_category": "bank_transfers_in"
        },
        {
            "feature_name": "is_direct_debit",
            "pattern": "^direct debit payment to",
            "fields": [
                "description"
            ],
            "hint_category": "low_confidence"
        },
        {
            "feature_name": "is_inter_company",
            "pattern": "inter (acc txf|co cred)",
            "fields": [
                "description"
            ],
            "hint_category": "internal_transfers"
        },
        {
            "feature_name": "has_exchange_rate",
            "pattern": "exchange rate",
            "fields": [
                "description"
            ],
            "hint_category": "fx_fees"
        },
        {
            "feature_name": "is_slc_loan",
            "pattern": "slc loans",
            "fields": [
                "description"
            ],
            "hint_category": "grants_subsidies"
        },
        {
            "feature_name": "is_council_payment",
            "pattern": "(county council|city council|city co|borough council|county borou|cc gcf|lb bromley|lb lewisham|surrey cc|kcc payment|bcp council)",
            "fields": [
                "description"
            ],
            "hint_category": "grants_subsidies"
        },
        {
            "feature_name": "is_nhs_payment",
            "pattern": "(nhs|nhs england|nhs gg|nhs ne|nhs south)",
            "fields": [
                "description"
            ],
            "hint_category": "bank_transfers_in"
        }
    ],
    "composite_features": [
        {
            "feature_name": "is_payroll_individual",
            "conditions": [
                {
                    "field": "description",
                    "match_type": "regex",
                    "pattern": "^[a-z][a-z]+ [a-z][a-z]+( fp \\d{2}/\\d{2}/\\d{2})?$"
                },
                {
                    "field": "transaction_type",
                    "match_type": "equals",
                    "value": "Debit"
                },
                {
                    "field": "amount",
                    "match_type": "between",
                    "min": 200,
                    "max": 5000
                }
            ],
            "hint_category": "salaries_wages"
        },
        {
            "feature_name": "is_hmrc_paye_debit",
            "conditions": [
                {
                    "field": "description",
                    "match_type": "any_contains",
                    "keywords": [
                        "hmrc",
                        "cumbernauld",
                        "paye"
                    ]
                },
                {
                    "field": "transaction_type",
                    "match_type": "equals",
                    "value": "Debit"
                }
            ],
            "hint_category": "paye_hmrc"
        },
        {
            "feature_name": "is_corp_tax_debit",
            "conditions": [
                {
                    "field": "description",
                    "match_type": "any_contains",
                    "keywords": [
                        "hmrc corp tax",
                        "hmrc shipley",
                        "corporation tax"
                    ]
                },
                {
                    "field": "transaction_type",
                    "match_type": "equals",
                    "value": "Debit"
                }
            ],
            "hint_category": "corporation_tax"
        },
        {
            "feature_name": "is_large_internal_transfer",
            "conditions": [
                {
                    "field": "description",
                    "match_type": "regex",
                    "pattern": "^bx\\d{8}"
                },
                {
                    "field": "amount",
                    "match_type": "between",
                    "min": 10000,
                    "max": 99999999
                }
            ],
            "hint_category": "internal_transfers"
        },
        {
            "feature_name": "is_card_payout_credit",
            "conditions": [
                {
                    "field": "description",
                    "match_type": "any_contains",
                    "keywords": [
                        "elavon",
